# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Fastify server listens on (default: 3001)
PORT=3001

# Allowed CORS origin for the game client (default: http://localhost:5173)
CLIENT_URL=http://localhost:5173

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/smp
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/ScrapMetalDB?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/ScrapMetalDB

# ── Test helpers ──────────────────────────────────────────────────────────────

# Set to 1 to skip mongoose.connect (used automatically by vitest tests)
# SKIP_MONGO=1
